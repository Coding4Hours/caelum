{
  "compilerOptions": {
    "types": [
      "bun",
      "express"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "noImplicitAny": false
  },
  "include": [
    "src/**/*.ts"
  ]
}
