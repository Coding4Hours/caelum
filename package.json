{
  "name": "@coding4hours/caelumjs",
  "version": "1.4.0",
  "description": "Easily create your own web proxy with no experience required.",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "author": "Coding4hours",
  "license": "MIT",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir=./dist --format=esm --target=bun --sourcemap=linked && bunx tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@mercuryworkshop/epoxy-transport": "^3.0.1",
    "@mercuryworkshop/libcurl-transport": "^2.0.5",
    "@mercuryworkshop/scramjet": "2.0.67-alpha.1",
    "@mercuryworkshop/scramjet-controller": "0.0.13",
    "@mercuryworkshop/wisp-js": "^0.4.1",
    "express": "^5.2.1",
    "nanoid": "^5.1.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.6"
  }
}
